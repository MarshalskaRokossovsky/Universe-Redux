                        "    SetRelationsToPlayer('Best',0,0,1,0,1,0);",
                        "}",
                        "TransferToRuin('WB');",
                        "",
                        "ShipStatus(Player(), 0, 0); //Торговый статус",
                        "ShipStatus(Player(), 1,  0); //Пиратский статус",
                        "ShipStatus(Player(), 2, 100); //Военный статус",
                        "AddItemToShip(Player(),CreateQuestItem('Usl_Rvk',startRace));",
                        "",
                        "ShipRaiseRank(Player(),2);",
                        "",
                        "CloseAllOpenPlayerSector();"
                    ]
