                        "}",
                        "if (startRace == Peleng) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,1,0,0);",
                        "    SetRelationsToPlayer('Bad',0,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Normal',0,0,1,0,0,0);",
                        "    SetRelationsToPlayer('Good',1,1,0,0,0,1);",
