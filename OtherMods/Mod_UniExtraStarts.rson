                    "Parent": 32,
                    "#": 15,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "if (startRace == Maloc) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,0,0,1,0,1);",
                        "    SetRelationsToPlayer('Good',0,0,1,0,1,0);",
                        "    SetRelationsToPlayer('Best',0,1,0,0,0,0);",
                        "}",
                        "if (startRace == Peleng) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,1,0,0);",
                        "    SetRelationsToPlayer('Bad',0,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Normal',1,0,1,0,0,0);",
                        "    SetRelationsToPlayer('Good',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Best',0,1,0,0,0,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_FuelTanks), 1, 0);",
                        "}",
                        "if (startRace == People) {",
                        "    SetRelationsToPlayer('Normal',1,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,1,0,1,1,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,0,0,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_Engine), 1, 0);",
                        "}",
                        "if (startRace == Fei) {",
                        "    SetRelationsToPlayer('Bad',1,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,1,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_FuelTanks), 1, 0);",
                        "}",
                        "if (startRace == Gaal) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,1,0,1,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,0,1,0);",
                        "}",
                        "TransferToPlanet(ShipStar(Player()), 2);",
                        "startPlanet=GetShipPlanet(Player());",
                        "ShipStatus(Player(), 0, 50); //Торговый статус",
                        "ShipStatus(Player(), 1, 10); //Пиратский статус",
                        "ShipStatus(Player(), 2, 40); //Военный статус",
                        "",
                        "SpecialToEquipment(FindBonusByNameInCfg('353'),ShipEqInSlot(Player(),t_Hull));",
                        "Chameleon(Player());",
                        "",
                        "SFT('UniExtraStarts logging:char5MissionState = '+char5MissionState);",
                        "tint = 100000/GalaxyDiffLevels(1)+Rnd(1,50)*10;",
                        "for (i=2; i < 3; i=i+1)",
                        "{",
                        "    star = StarNearbyStars(ShipStar(Player()), i);",
                        "    if (StarOwner(star) == 0)",
                        "    {",
                        "        for(j=0;j < StarPlanets(star);j=j+1)",
                        "        {",
                        "            if (PlanetOwner(StarPlanets(star, j)) != 6)",
                        "            {",
                        "                char5QuestPlanet = StarPlanets(star, j);",
                        "                break;",
                        "            }",
                        "        }",
                        "    }",
                        "}",
                        "tstr1= //назначаем курьерскую миссию",
                        "    CT('Quest.Info.CurQuests.NotAccepted')",
                        "    +Format('<br>')+Format('<br>')+",
                        "    Format(CT('Quest.Info.FromPlanet'),",
                        "        '<Planet'+'>',Name(startPlanet),",
                        "        '<System'+'>',Name(PlanetToStar(startPlanet)),",
                        "        '255,240,100')",
                        "    +Format('<br>')+Format('<br>')+",
                        "    Format(CT('Quest.Info.CountDay'),",
                        "        '<Day'+'>',340-CurTurn(),",
                        "        '255,240,100')",
                        "    +Format('<br>')+Format('<br>')+",
                        "    Format(CT('UniStarCourierMissions.'+startRace+'.Start'),",
                        "        '<ToPlanet'+'>',Name(char5QuestPlanet),",
                        "        '<ToStar'+'>',Name(PlanetToStar(char5QuestPlanet)),",
                        "        '<Date'+'>',GameDateTxtByTurn(340),",
                        "        '<Money'+'>',tint,",
                        "        '255,240,100');",
                        "Ether(3,'unistartEtherID',tstr1);",
                        "char5MissionState=1;",
                        "char5QuestItem=CreateQuestItem('Usl_Courier_'+startRace,startRace);",
                        "AddItemToShip(Player(),char5QuestItem);"
                    ]
                },
