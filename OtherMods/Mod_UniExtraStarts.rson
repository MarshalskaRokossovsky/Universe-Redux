                        "if (startRace == Maloc) {",
                        "    SetRelationsToPlayer('Bad',0,0,0,1,1,0);",
                        "    SetRelationsToPlayer('Normal',0,0,1,0,0,1);",
                        "    SetRelationsToPlayer('Good',1,1,0,0,0,0);",
