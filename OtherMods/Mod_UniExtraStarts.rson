                        "ShipStatus(Player(), 1, 40); //Пиратский статус",
                        "ShipStatus(Player(), 2, 50); //Военный статус",
                        "",
                        "if (CurrentMods('ShusRangers\\ShuMercs')) {",
                        "    SpecialToEquipment(FindBonusByNameInCfg(acryn_name),ShipEqInSlot(Player(),t_Hull));",
                        "    Chameleon(Player());",
                        "}"
                    ]
                },
