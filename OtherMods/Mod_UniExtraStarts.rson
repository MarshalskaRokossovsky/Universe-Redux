                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 420,
                    "Pos.y": 350,
                    "Parent": -1,
                    "#": 65,
                    "Code.Type": "DialogBegin",
                    "Code": 
                    [
                        "if (GetShipPlanet(Player()) == char5QuestPlanet && char5MissionState==1) { //завершаем квест курьера если миссия выполняется и ГГ говорит с правителем целевой планеты",
                        "    if(~FindItemInShip(Player(),char5QuestItem)) {",
                        "        char5MissionState=2; //задание курьера выполнено успешна",
                        "        DText(CT('UniStarCourierMissions.'+startRace+'.End'));",
                        "        tstr1= //текущая курьерская миссия",
                        "                    CT('Quest.Info.OldQuests.Accepted')",
                        "                    +Format('<br>')+Format('<br>')+",
                        "                    Format(CT('Quest.Info.FromPlanet'),",
                        "                        '<Planet'+'>',Name(startPlanet),",
                        "                        '<System'+'>',Name(PlanetToStar(startPlanet)),",
                        "                        '255,240,100')",
                        "                    +Format('<br>')+",
                        "                    Format(CT('Quest.Info.FromPlanet'),",
                        "                        '<Day'+'>',340-CurTurn(),",
                        "                        '255,240,100')",
                        "                    +Format('<br>')+",
                        "                    Format(CT('UniStarCourierMissions.'+startRace+'.Start'),",
                        "                        '<ToPlanet'+'>',Name(char5QuestPlanet),",
                        "                        '<ToStar'+'>',Name(PlanetToStar(char5QuestPlanet)),",
                        "                        '<Date'+'>',GameDateTxtByTurn(340),",
                        "                        '<Money'+'>',tint,",
                        "                        '255,240,100');",
                        "                Ether(4,'unistartEtherID',tstr1);",
                        "        Sound('Sound.QuestOk');",
                        "        GetItemFromShip(Player(),char5QuestItem);",
                        "        FreeItem(char5QuestItem);",
                        "        RelationToRanger(char5QuestPlanet,Player(),90);",
                        "    }",
                        "}",
                        "",
                        "if (startClass == '17' && GetShipRuins(Player()) && !char17State) {",
                        "    dword ranger = BuyRanger(NearCivilPlanet(Player()));",
                        "    ShipSetPartner(ranger, Player(), 730);",
                        "    TransferShip(ranger,GetShipRuins(Player()));",
                        "    ranger = BuyRanger(NearCivilPlanet(Player()));",
                        "    ShipSetPartner(ranger, Player(), 730);",
                        "    TransferShip(ranger,GetShipRuins(Player()));",
                        "    DAddText(CT('Script.Mod_UniExtraStarts.Char17Addition'));",
                        "    char17State=1;",
                        "}",
                        "",
                        "",
                        "if(CurTurn() < 302) {",
                        "    if (GetShipRuins(Player())) startRuinsType=ShipTypeN(GetShipRuins(Player()));",
                        "    else startRuinsType=0;",
                        "",
                        "    if (startRuinsType != t_RC && !mSBeginState) {",
                        "        if (1==int((int(startClass)-1)/5)) DAddText(Format(CT('Script.Mod_UniExtraStarts.GotoRCPirate'),'<1'+'>',startSystemName,'<0'+'>', startRCName, '255,240,100'));",
                        "        else DAddText(Format(CT('Script.Mod_UniExtraStarts.GotoRC'),'<1'+'>',startSystemName,'<0'+'>', startRCName,'255,240,100'));",
                        "        Ether(3,'UniStart_GoToRC',Format(CT('Script.Mod_UniExtraStarts.GotoRCQuest'),'<1'+'>',startSystemName,'<0'+'>', startRCName,'255,240,100'));",
                        "        mSBeginState=1;",
                        "    }",
                        "}",
                        "",
                        "if (GetShipRuins(Player())) {",
                        "    if (ShipTypeN(GetShipRuins(Player())) == t_RC && mSBeginState==1) {",
                        "        Ether(4,'UniStart_GoToRC','');",
                        "        Sound('Sound.QuestOk');",
                        "        mSBeginState=2;",
                        "    }",
                        "}"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 820,
                    "Pos.y": 550,
                    "Parent": -1,
                    "#": 69,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "if (startClass == 16) {",
                        "    //SFT('UniExtraStarts logging:char16: startClass == 16, обработка начата');",
                        "",
                        "    if (char16LiberationPoints > 100) {",
                        "        //SFT('UniExtraStarts logging:char16: Очки освобождения превысили 100, ограничиваем до 100');",
                        "        char16LiberationPoints = 100;",
                        "    }",
                        "",
                        "    if (char16LiberationTimer == 0) {",
                        "        if (char16LiberationPoints > 0) {",
                        "            //SFT('UniExtraStarts logging:char16: Таймер истёк, уменьшаем очки освобождения на 1');",
                        "            char16LiberationPoints = char16LiberationPoints - 1;",
                        "        }",
                        "",
                        "    }",
                        "",
                        "    if (char16LiberationTimer > 0) {",
                        "        //SFT('UniExtraStarts logging:char16: Таймер ещё активен (' + char16LiberationTimer + '), уменьшаем на 1');",
                        "        char16LiberationTimer = char16LiberationTimer - 1;",
                        "    }",
                        "",
                        "    if (char16LiberationPoints > 70 && !char16BufFlag) {",
                        "        //SFT('UniExtraStarts logging:char16: Очки освобождения (' + char16LiberationPoints + ') > 70 и буфер неактивен — вызываем Char16Buf()');",
                        "        Char16Buff();",
                        "        Ether(7,'',\"Враги повержены - эта мысль воодушевляет вас всё больше и больше. Вы готовы прямо сейчас кинуть в бой и отбить ещё одну систему. И ещё. И ещё. И стрелять готовы всё точнее и точнее.\");",
                        "    }",
                        "",
                        "    if (char16LiberationPoints < 70 && char16BufFlag) {",
                        "        //SFT('UniExtraStarts logging:char16: Очки освобождения (' + char16LiberationPoints + ') < 70 и буфер активен — вызываем Char16DeBuf()');",
                        "        Char16DeBuf();",
                        "        Ether(7,'',\"Очень долго уже пушки вашего корабля молчат. С каждым днём вас всё больше гнетёт мысль, что вы не вносите свой посильный вклад в победу над врагами разумной жизни. Это не могло и не сказывается лучшим образом на ваши навыки пилота.\");",
                        "    }",
                        "",
                        "    // Перебор галактических событий в обратном порядке",
                        "    for (i = GalaxyEvents() - 1; i > -1; i = i - 1) {",
                        "        if(GalaxyEventType(i) == 'PlayerLiberatesSystem') {",
                        "            //SFT('UniExtraStarts logging:char16: Найдено событие PlayerLiberatesSystem на ходу '+ CurTurn());",
                        "",
                        "            char16LiberationTimer = 90;",
                        "            //SFT('UniExtraStarts logging:char16: Установлен таймер освобождения на 90 ходов');",
                        "",
                        "            int points_to_add = round(395 - 45 * GalaxyTechLevel() / 7);",
                        "            char16LiberationPoints = char16LiberationPoints + points_to_add;",
                        "            //SFT('UniExtraStarts logging:char16: Добавлено ' + points_to_add + ' очков освобождения. Текущий ГТУ: ' + GalaxyTechLevel() + ', итого очков: ' + char16LiberationPoints);",
                        "",
                        "            break; // Обрабатываем только последнее событие",
                        "        }",
                        "    }",
                        "}"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 820,
                    "Pos.y": 610,
                    "Parent": -1,
                    "#": 70,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "if (startClass==18) {",
                        "    if (startRace == 2 && ShipPilotRace(Player()) == People) {",
                        "        if (!CurTurn()%10) {",
                        "            ChangeGlobalRelationsPlanets(Player(),0,2,2,1+2+0+8+16);",
                        "            ChangeGlobalRelationsPlanets(Player(),0,4,100,4);",
                        "        }",
                        "    }",
                        "}"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 820,
                    "Pos.y": 640,
                    "Parent": -1,
                    "#": 71,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "if (CurTurn%300 == 0) {",
                        "    if (startClass==19 && startRace == 4) {",
                        "        char19GaalFlag = Rnd(0,3);",
                        "        if (char19GaalFlag==0) tstr1 = \"малоков\";",
                        "        if (char19GaalFlag==1) tstr1 = \"пеленгов\";",
                        "        if (char19GaalFlag==2) tstr1 = \"людей\";",
                        "        if (char19GaalFlag==3) tstr1 = \"фэян\" ;",
                        "    Ether(7,'',\"Магистрат Безопасности постановил: ввиду текущей политической обстановки необходимо срочно нанести удар по экономике \"+tstr1);",
                        "    if(ShipFindCustomShipInfoByType(Player(),'UniStart_char19') != -1) ShipCustomShipInfoData(Player(), 'UniStart_char19', 1, char19GaalFlag);",
                        "}",
                        "if(ShipInPirateClan && ShipFindCustomShipInfoByType(Player(),'UniStart_char19') != -1) ShipDeleteCustomShipInfo(Player(),'UniStart_char19');"
                    ]
                },
