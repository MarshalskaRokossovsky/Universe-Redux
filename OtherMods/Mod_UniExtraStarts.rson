                        "                    tstr1= //текущая курьерская миссия",
                        "                CT('Quest.Info.OldQuests.NotAccepted')",
                        "                +Format('<br>')+Format('<br>')+",
                        "                Format(CT('Quest.Info.FromPlanet'),",
                        "                    '<Planet'+'>',Name(startPlanet),",
                        "                    '<System'+'>',Name(PlanetToStar(startPlanet)),",
                        "                    '255,240,100')",
                        "                +Format('<br>')+",
                        "                Format(CT('Quest.Info.FromPlanet'),",
                        "                    '<Day'+'>',340-CurTurn(),",
                        "                    '255,240,100')",
                        "                +Format('<br>')+",
                        "                Format(CT('UniStarCourierMissions.'+startRace+'.Start'),",
                        "                    '<ToPlanet'+'>',Name(char5QuestPlanet),",
                        "                    '<ToStar'+'>',Name(PlanetToStar(char5QuestPlanet)),",
                        "                    '<Date'+'>',GameDateTxtByTurn(340),",
                        "                    '<Money'+'>',tint,",
                        "                    '255,240,100');",
                        "            Ether(5,'unistartEtherID',tstr1);",
                        "            Sound('Sound.QuestCancel');",
                        "            RelationToRanger(char5QuestPlanet,Player(),20);",
                        "        }",
                        "    }",
                        "}"
                    ]
                }
            ],
