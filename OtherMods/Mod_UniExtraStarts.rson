                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 40,
                    "Pos.y": 0,
                    "Parent": 31,
                    "#": 14,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "//стартует на научке в третьем научном звании",
                        "if (startRace == Maloc) {",
                        "    SetRelationsToPlayer('Normal',1,1,1,1,0,1);",
                        "    SetRelationsToPlayer('Good',0,0,0,0,1,0);",
                        "}",
                        "if (startRace == Peleng) {",
                        "    SetRelationsToPlayer('Bad',0,0,0,1,0,0);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',1,0,1,0,1,1);",
                        "}",
                        "if (startRace == People) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,1);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,1,0);",
                        "}",
                        "if (startRace == Fei) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,1);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,1,0);",
                        "}",
                        "if (startRace == Gaal) {",
                        "    SetRelationsToPlayer('Bad',1,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,0,1,0,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,1,1,0);",
                        "}",
                        "TransferToRuin('SB');",
                        "",
                        "ShipStatus(Player(), 0, 50); //Торговый статус",
                        "ShipStatus(Player(), 1,  0); //Пиратский статус",
                        "ShipStatus(Player(), 2, 50); //Военный статус",
                        "",
                        "ItemImprovement(ShipEqInSlot(Player(), t_Engine), 1, 0);",
                        "ItemImprovement(ShipEqInSlot(Player(), t_FuelTanks), 1, 0);",
                        "//ItemImprovement(ShipEqInSlot(Player(), t_CargoHook), 1, 0);",
                        "ItemImprovement(ShipEqInSlot(Player(), t_Radar), 1, 0);",
                        "ItemImprovement(ShipEqInSlot(Player(), t_Weapon1), 1, 0);",
                        "//SFT('UniExtraStarts logging:активируем скрипт');",
                        "if(!IsScriptActive('Mod_ExpScienceRanks')) ScriptRun(ShipStar(Player()), NearCivilPlanet(Player()), 'Mod_ExpScienceRanks');",
                        "ShipAddCustomShipInfo(Player(),'Science_rank_infos');",
                        "//SFT('UniExtraStarts logging:приступаем к назначению ранга ученого');",
                        "",
                        "HullSeries(ShipItems(Player(),0),FindSeriesByName(CT('HullType.UniStart_Hulls_Diplomat.Name')));",
                        "//if(~ShipFindCustomShipInfoByType(Player(), 'Science_rank_infos'))",
                        "//{",
                        "    //SFT('UniExtraStarts logging:условие выполнилось');",
                        "    int new_rank = 3;//NumberBox('Bm.FormShip2.2SR3_img', \"Укажите желаемое звание\", 1, 8, 8, '', min(PlayerScienceRank['CurrentRank'] + 1, 8));",
                        "",
                        "    if(new_rank && new_rank != PlayerScienceRank['CurrentRank'])",
                        "    {",
                        "        PlayerScienceRank['CurrentRank'] = new_rank;",
                        "",
                        "        if(new_rank < 8)",
                        "        {",
                        "            PlayerScienceRank['HolesToNextRankLeft'] = PlayerScienceRank['HolesToRankRequired', PlayerScienceRank['CurrentRank'] + 1] - PlayerScienceRank['HolesExplored'];",
                        "",
                        "            if(PlayerScienceRank['CurrentRank'] == 5) int rank_image_num = 5;",
                        "            else if(PlayerScienceRank['CurrentRank'] == 0 || PlayerScienceRank['CurrentRank'] == 7) rank_image_num = 2;",
                        "            else if(PlayerScienceRank['CurrentRank'] == 3 || PlayerScienceRank['CurrentRank'] == 8) rank_image_num = 4;",
                        "            else rank_image_num = 3;",
                        "",
                        "            ShipCustomShipInfoData(Player(), 'Science_rank_infos', 1, rank_image_num);",
                        "            ShipCustomShipInfoData(Player(), 'Science_rank_infos', 2, PlayerScienceRank['HolesToNextRankLeft']);",
                        "            ShipCustomShipInfoTextData(Player(), 'Science_rank_infos', 1, CT('RankScientific.' + PlayerScienceRank['CurrentRank'] + '.Text'));",
                        "            ShipCustomShipInfoTextData(Player(), 'Science_rank_infos', 2, CT('RankScientific.' + PlayerScienceRank['CurrentRank'] + '.Name'));",
                        "",
                        "            InterfaceState('Ship', 'CustomRankImage_2_NR', 0);",
                        "            if(PlayerScienceRank['CurrentRank'] == 1) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2BH_img');",
                        "            else if(PlayerScienceRank['CurrentRank'] == 2) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR1_img');",
                        "            else if(PlayerScienceRank['CurrentRank'] == 3) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR1_img');",
                        "            else if(PlayerScienceRank['CurrentRank'] == 4) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR2_img');",
                        "            else if(PlayerScienceRank['CurrentRank'] == 5) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR2_img');",
                        "            else if(PlayerScienceRank['CurrentRank'] == 6) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR3_img');",
                        "            else if(PlayerScienceRank['CurrentRank'] == 7) InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR3_img');",
                        "        }",
                        "        else",
                        "        {",
                        "            PlayerScienceRank['HolesToNextRankLeft'] = 0;",
                        "",
                        "            rank_image_num = 4;",
                        "            ShipCustomShipInfoData(Player(), 'Science_rank_infos', 1, rank_image_num);",
                        "            ShipCustomShipInfoData(Player(), 'Science_rank_infos', 2, -10);",
                        "            ShipCustomShipInfoTextData(Player(), 'Science_rank_infos', 1, CT('RankScientific.' + PlayerScienceRank['CurrentRank'] + '.Text'));",
                        "            ShipCustomShipInfoTextData(Player(), 'Science_rank_infos', 2, CT('RankScientific.' + PlayerScienceRank['CurrentRank'] + '.Name'));",
                        "",
                        "            InterfaceState('Ship', 'CustomRankImage_2_NR', 0);",
                        "            InterfaceImage('Ship', 'CustomRankImageL_' + rank_image_num, 'GI,Bm.FormShip2.2SR4_img');",
                        "        }",
                        "",
                        "        Sound('Sound.Repair');",
                        "    }",
                        "//}",
                        "//SFT('UniExtraStarts logging:назначили назначению ранга ученого');"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 40,
