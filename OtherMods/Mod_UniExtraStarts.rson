                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 40,
                    "Pos.y": 0,
                    "Parent": 43,
                    "#": 26,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "str flag;",
                        "if (startRace == Maloc) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,1,0,1,1,0);",
                        "    SetRelationsToPlayer('Best',1,0,1,0,0,0);",
                        "    flag = 'malocflag';",
                        "}",
                        "if (startRace == Peleng) {",
                        "    SetRelationsToPlayer('Bad',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',1,1,1,1,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,0,1,0);",
                        "    flag = 'pelengflag';",
                        "}",
                        "if (startRace == People) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Best',1,0,1,1,1,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_Engine), 1, 0);",
                        "    flag = 'peopleflag';",
                        "}",
                        "if (startRace == Fei) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,1,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_Engine), 1, 0);",
                        "    flag = 'feiflag';",
                        "}",
                        "if (startRace == Gaal) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',1,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,0,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_Engine), 1, 0);",
                        "    flag = 'gaalflag';",
                        "}",
                        "TransferToRuin('WB');",
                        "",
                        "ShipStatus(Player(), 0, 10); //Торговый статус",
                        "ShipStatus(Player(), 1, 0); //Пиратский статус",
                        "ShipStatus(Player(), 2, 90); //Военный статус",
                        "",
                        "if(CurrentMods('ShusRangers\\ShuBounty')) {",
                        "    AddItemToShip(Player(),CreateQuestItem(flag));",
                        "}",
                        "HullSeries(ShipItems(Player(),0),FindSeriesByName(CT('HullType.UniStart_Hulls_Veteran.Name')));",
                        "AddItemToShip(Player(),CreateQuestItem('Usl_Rvk',startRace));"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 490,
                    "Pos.y": 380,
                    "Parent": -1,
                    "#": 27,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "//забираем параметры игрока",
                        "startRace = ShipPilotRace(Player());",
                        "startClass = GetParFromTxt('SpaceRangersHD\\ModsCFG.txt', 'CharacterBackground');",
                        "startSystemName = Name(ShipStar(Player()));",
                        "startRCName=Name(GetShipRuins(Player()));",
                        "dword pirateStar = PlanetToStar(PlanetPirateClan());",
                        "dword pirateSector = StarToCon(pirateStar);",
                        "//Ether(3,'','в переменной записано значение '+startClass);",
                        "if (1==int((int(startClass)-1)/5)) {",
                        "    ShipJoinsClan(Player());",
                        "    isPlayerInClan=1;",
                        "}",
                        "//SFT('UniExtraStarts logging:class is '+int(startClass)+', class%5 = '+int(int(startClass)/5));",
                        "//снаряжаем игрока, поправляем размер корпуса",
                        "GivePlayerAllEq(startRace,startClass);",
                        "if(ShipFreeSpace(Player()) <= 1)",
                        "{",
                        "    ItemSize(ShipEqInSlot(Player(), t_Hull), ItemSize(ShipEqInSlot(Player(), t_Hull)) + abs(ShipFreeSpace(Player())) + RndObject(5, 10, Player()));",
                        "}",
                        "//на случай переноса игрока с ЦР запихиваем склад ему в трюм",
                        "dword item;",
                        "for(i = StorageItems() - 1; i >= 0; i = i - 1) {",
                        "    item = GetItemFromStorage(i);",
                        "    AddItemToShip(Player(), item);",
                        "}",
                        "//чистим трюм от товаров",
                        "int cnt = 0;",
                        "for(i = 0; i <= 7; i=i+1)",
                        "{",
                        "    cnt = GoodsCount(Player(), i);",
                        "    if(cnt > 0)",
                        "    {",
                        "        ShipGoods(Player(), i, -cnt);",
                        "    }",
                        "}",
                        "//сбрасываем оставшиеся в трюме вещи на склад",
                        "for(i = ShipItems(Player()) - 1; i >= 0; i = i - 1) {",
                        "    if (ItemIsInUse(ShipItems(Player(),i)))  continue;",
                        "    item = GetItemFromShip(Player(), i);",
                        "    AddItemToStorage(GetShipRuins(Player()),item);",
                        "}",
                        "",
                        "//ищем Ницигац для изгоя",
                        "for(i = 0; i < 2; i=i+1)",
                        "{",
                        "    star = ConStar(pirateSector, i);",
                        "    if(star != pirateStar)",
                        "    {",
                        "        char10Star = star;",
                        "        break;",
                        "    }",
                        "}",
                        "//доп перенос мостика на корпус при его смены, страховочный, подсмотрено у Klaxons",
                        "if(CurrentMods('Expansion\\ExpPilotBridge'))",
                        "{",
                        "    if(!GCntRun('Mod_ExpPilotBridge')) ScriptRun(ShipStar(Player()), PlanetPirateClan(), 'Mod_ExpPilotBridge');",
                        "    CreateActCodeEvent(t_OnPlayerChangeHull, 'PlayerBridgeHV_infos', Player(), ShipEqInSlot(Player(), t_Hull), 0, 0);",
                        "}"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 420,
                    "Pos.y": 380,
                    "Parent": -1,
                    "#": 48,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "function SetRelationsToPlayer(str relation, int maloc,int peleng,int people,int fei,int gaal,int pirate)",
                        "{",
                        "    int int_relation;",
                        "    if (relation == 'Enemy') int_relation = 5;",
                        "    if (relation == 'Bad') int_relation = 20;",
                        "    if (relation == 'Normal') int_relation = 50;",
                        "    if (relation == 'Good') int_relation = 70;",
                        "    if (relation == 'Best') int_relation = 90;",
                        "    int bitset = 0;",
                        "    if (maloc) bitset = bitset+1;",
                        "    if (peleng) bitset = bitset+2;",
                        "    if (people) bitset = bitset+4;",
                        "    if (fei) bitset = bitset+8;",
                        "    if (gaal) bitset = bitset+16;",
                        "    if (pirate) {",
                        "        RelationToRanger(PlanetPirateClan(),Player(),int_relation);",
                        "        ChangeGlobalRelationsShips(Player(),0,0,int_relation,1+2+4+8+16+32,128);",
                        "        ChangeGlobalRelationsShips(Player(),0,1,int_relation,1+2+4+8+16+32,128);",
                        "    }",
                        "    if (bitset) {",
                        "        ChangeGlobalRelationsPlanets(Player(), 0, 1, int_relation, bitset);",
                        "        ChangeGlobalRelationsPlanets(Player(), 0, 0, int_relation, bitset);",
                        "    }",
                        "}",
                        "",
                        "function ClearPlayerEq() {",
                        "    for(int i = ShipItems(Player()) - 1; i >= 1; i = i - 1) FreeItem(GetItemFromShip(Player(), i));",
                        "}",
                        "",
                        "function TransferToRuin(str base) {",
                        "    int base_int = 0;",
                        "    if (base == 'RC') base_int = 6;",
                        "    if (base == 'WB') base_int = 7;",
                        "    if (base == 'SB') base_int = 8;",
                        "    if (base == 'BK') base_int = 9;",
                        "    if (base == 'MC') base_int =10;",
                        "    if (base == 'PB') base_int =11;",
                        "    if (base == 'CB') base_int =12;",
                        "    if (base == 'MB') base_int =13;",
                        "",
                        "    transfer_ruin = 0;",
                        "    for(int i = 0; i < GalaxyStars(); i = i + 1) {",
                        "        star = StarNearbyStars(ShipStar(Player()), i);",
                        "        transfer_ruin = StarRuins(star, base);",
                        "        if(transfer_ruin) break;",
                        "    }",
                        "    if(!transfer_ruin)",
                        "    {",
                        "        SFT('UniExtraStarts logging:BASE WAS NOT FOUND');",
                        "        for(i = 0; i < GalaxyStars(); i = i + 1){",
                        "            dword star = StarNearbyStars(ShipStar(Player()), i);",
                        "            if (StarRuins(star) < 3){",
                        "                if(base_int ==13) {",
                        "                    SFT('UniExtraStarts logging:Merc Center was not found, spawn in '+ star);",
                        "                    SpawnMercCenter(star);",
                        "                }",
                        "                else BuildRuins(star, base_int);",
                        "            }",
                        "            transfer_ruin = StarRuins(star, base);",
                        "        }",
                        "    }",
                        "    TransferShip(Player(), transfer_ruin);",
                        "    ShipChangeStar(Player(), ShipStar(transfer_ruin));",
                        "    for(i = StorageItems() - 1; i >= 0; i = i - 1)",
                        "    {",
                        "        dword curItem = GetItemFromStorage(i);",
                        "        AddItemToStorage(transfer_ruin, curItem);",
                        "    }",
                        "}",
                        "",
                        "function TransferToPlanet(dword star, int index) {",
                        "    int k = 1;",
                        "    for (i = 0; i < StarPlanets(star); i = i+1) {",
                        "        if (PlanetOwner(StarPlanets(star,i)) == 6) continue;",
                        "        else {",
                        "            if (k == index) {",
                        "                TransferShip(Player(), StarPlanets(star,i));",
                        "                index=i;",
                        "                ShipChangeStar(Player(), star);",
                        "                GotoGov(1);",
                        "                break;",
                        "            }",
                        "            k = k+1;",
                        "        }",
                        "    }",
                        "    for(i = StorageItems() - 1; i >= 0; i = i - 1)",
                        "    {",
                        "        dword curItem = GetItemFromStorage(i);",
                        "        AddItemToStorage(StarPlanets(star,index), curItem);",
                        "    }",
                        "}",
                        "",
                        "",
                        "",
                        "function GiveEq(str equipment, str race, str class) {",
                        "    int type = 0;",
                        "    if (equipment == 'Engine') type = t_Engine;",
                        "    if (equipment == 'FuelTanks') type = t_FuelTanks;",
                        "    if (equipment == 'RepairRobot') type = t_RepairRobot;",
                        "    if (equipment == 'CargoHook') type = t_CargoHook;",
                        "    if (equipment == 'DefGenerator') type = t_DefGenerator;",
                        "    if (equipment == 'Radar') type = t_Radar;",
                        "    if (equipment == 'Scaner') type = t_Scaner;",
                        "    str tstr1 = 'UniStartSettings.'+class+'.'+race+'.Equipment.';",
                        "    if (int(CT(tstr1+equipment+'.level'))) {",
                        "        dword item = CreateEquipment(type,int(CT(tstr1+equipment+'.size')),int(CT(tstr1+equipment+'.level')),race);",
                        "        AddItemToShip(Player(), item);",
                        "        if (ShipInPirateClan(Player())) ItemOwner(item,PirateClan);",
                        "        if (int(CT('UniStartSettings.'+class+'.'+race+'.EqStatus'))<100) ItemDurability(ShipEqInSlot(Player(), i),int(CT('UniStartSettings.'+class+'.'+race+'.EqStatus')));",
                        "        ItemIsInUse(item, Player(), 1);",
                        "    }",
                        "}",
                        "",
                        "function Char16Buff() {",
                        "    char16BufFlag = 1;",
                        "    ShipSpecialBonuses(Player(), 9, 35);//bonWEnergy",
                        "    ShipSpecialBonuses(Player(), 10, 35);//bonWSplinter",
                        "    ShipSpecialBonuses(Player(), 11, 35);//bonWMissile",
                        "    ShipSpecialBonuses(Player(), 12, 70);//bonWRadius",
                        "    ShipSpecialBonuses(Player(), 17, 7);//bonDef",
                        "    ShipSpecialBonuses(Player(), 15, 21);//bonDroid",
                        "}",
                        "",
                        "function Char16DeBuff() {",
                        "    ShipSpecialBonuses(Player(), 9, ShipSpecialBonuses(Player(), 9)-35);//bonWEnergy",
                        "    ShipSpecialBonuses(Player(), 10, ShipSpecialBonuses(Player(), 10)-35);//bonWSplinter",
                        "    ShipSpecialBonuses(Player(), 11, ShipSpecialBonuses(Player(), 11)-35);//bonWMissile",
                        "    ShipSpecialBonuses(Player(), 12, ShipSpecialBonuses(Player(), 12)-70);//bonWRadius",
                        "    ShipSpecialBonuses(Player(), 17, ShipSpecialBonuses(Player(), 17)-7);//bonDef",
                        "    ShipSpecialBonuses(Player(), 15, ShipSpecialBonuses(Player(), 15)-21);//bonDroid",
                        "    char16BufFlag = 0;",
                        "}",
                        "",
                        "function GivePlayerAllEq(str race, str class) {",
                        "    ClearPlayerEq();",
                        "    GiveEq('Engine',race,class);",
                        "    GiveEq('FuelTanks',race,class);",
                        "    GiveEq('RepairRobot',race,class);",
                        "    GiveEq('CargoHook',race,class);",
                        "    GiveEq('DefGenerator',race,class);",
                        "    GiveEq('Radar',race,class);",
                        "    GiveEq('Scaner',race,class);",
                        "",
                        "    int diff = GalaxyDiffLevels(7)/50;//емкость корпуса зависит от удачи",
                        "    str tstr1 = 'UniStartSettings.'+class+'.'+race+'.Equipment.Hull.';",
                        "    //SFT('UniExtraStarts logging:hull='+tstr1+'type'+','+tstr1+'size'+diff+','+tstr1+'level'+','+race+','+-1);",
                        "    //SFT('UniExtraStarts logging:hull='+int(CT(tstr1+'type'))+','+int(CT(tstr1+'size'+diff))+','+int(CT(tstr1+'level'))+','+race+','+-1);",
                        "    int size = int(CT(tstr1+'size'+diff));",
                        "    if (startClass == '1') size = size * 10/9;//акриновые корпуса изменяю структуру, возвращаем ту которая должна быть",
                        "    if (startClass == '7') size = size * 10/11;",
                        "    if (startClass == '14') size = size * 10/8;",
                        "    if (startClass == '5') size = size * 10/7;",
                        "    dword temp_hull = CreateHull(int(CT(tstr1+'type')),size,int(CT(tstr1+'level')),race,-1,isPlayerInClan);",
                        "    HullHP(temp_hull, 'To100');",
                        "    FreeItem(GetItemFromShip(Player(), 0));",
                        "    AddItemToShip(Player(), temp_hull);//int(CT(tstr1+'type'))//0рангер 1воин 2пират 3транспорт 4лайнер 5дипломат 6доминатор 7",
                        "    Chameleon(Player());",
                        "",
                        "    tstr1 = 'UniStartSettings.'+class+'.'+race+'.Equipment.Weapon';",
                        "    for(i=1;i<=5;i=i+1) {",
                        "        if (CT(tstr1+i+'.level') != '0') { //level=0 если слот пустой",
                        "            //SFT('UniExtraStarts logging:weapon='+tstr1+i+'.type'+','+tstr1+i+'.size'+','+tstr1+i+'.level'+','+race);",
                        "            //SFT('UniExtraStarts logging:weapon='+(CT(tstr1+i+'.type'))+','+int(CT(tstr1+i+'.size'))+','+int(CT(tstr1+i+'.level'))+','+race);",
                        "            dword item = CreateEquipment(int(CT(tstr1+i+'.type'))+50,int(CT(tstr1+i+'.size')),int(CT(tstr1+i+'.level')),race);",
                        "            AddItemToShip(Player(),item);",
                        "            ItemIsInUse(item, Player(), 1);",
                        "            if (ShipInPirateClan(Player())) ItemOwner(item,PirateClan);",
                        "            if (int(CT('UniStartSettings.'+class+'.'+race+'.EqStatus'))<100) ItemDurability(ShipEqInSlot(Player(), i),int(CT('UniStartSettings.'+class+'.'+race+'.EqStatus')));",
                        "            ItemIsInUse(item, Player(), 1);",
                        "        }",
                        "    }",
                        "",
                        "    int divider = 1;",
                        "    if (GalaxyDiffLevels(1)==50) divider = 1;",
                        "    if (GalaxyDiffLevels(1)==100) divider = 3;",
                        "    if (GalaxyDiffLevels(1)==150) divider = 5;",
                        "    if (GalaxyDiffLevels(1)==200) divider = 10;",
                        "    if (GalaxyDiffLevels(1)==250) divider = 15;",
                        "    if (GalaxyDiffLevels(1)==300) divider = 20;",
                        "    if (GalaxyDiffLevels(1)==350) divider = 25;",
                        "    if (GalaxyDiffLevels(1)==400) divider = 30;",
                        "    if (GalaxyDiffLevels(1)==450) divider = 35;",
                        "    if (GalaxyDiffLevels(1)==500) divider = 40;",
                        "",
                        "    ShipMoney(Player(),int(CT('UniStartSettings.'+class+'.'+race+'.Money'))/divider);",
                        "    for (i = 0;i<6;i=i+1) {",
                        "        ShipSkill(Player(),i,ShipSkill(Player(),i)+int(CT('UniStartSettings.'+class+'.'+race+'.Skill'+i)));",
                        "    }",
                        "",
                        "    for (i=1;i<=4;i=i+1) {",
                        "        int art = int(CT('UniStartSettings.'+class+'.'+race+'.Equipment.Art'+i+'.name'));",
                        "        //SFT('UniExtraStarts logging:UniStartSettings.'+class+'.'+race+'.Equipment.Art'+i+'.name');",
                        "        //SFT('UniExtraStarts logging:ART IS '+art);",
                        "        if (art != 0) {",
                        "            AddItemToShip(Player(),CreateArt(art, race));",
                        "        }",
                        "    }",
                        "}",
                        "",
                        "function CloseAllOpenPlayerSector()",
                        "{",
                        "    for(i = 0; i < GalaxySectors(); i = i + 1)",
                        "    {",
                        "        SectorVisible(GalaxySectors(i), 0); // 0 = закрыть сектор",
                        "    }",
                        "    // Открываем сектор игрока",
                        "    dword player_con = StarToCon(ShipStar(Player()));",
                        "    SectorVisible(player_con, 1); // 1 = открыть сектор",
                        "    int adjacent_count = 0;",
                        "    dword star_con;",
                        "    // Начинаем с 1, т.к. 0 - это сама система игрока",
                        "    for(i = 1; i < GalaxyStars() && adjacent_count < 2; i = i + 1)",
                        "    {",
                        "        // Получаем сектор звезды",
                        "        star_con = StarToCon(StarNearbyStars(ShipStar(Player()), i));",
                        "",
                        "        // Проверяем, не совпадает ли сектор со сектором игрока",
                        "        if((star_con != player_con) && !SectorVisible(star_con))",
                        "        {",
                        "            //SFT('UniExtraStarts logging:условие по сектору выполнилось');",
                        "            // Открываем сектор",
                        "            SectorVisible(star_con, 1);",
                        "            adjacent_count = adjacent_count + 1;",
                        "        }",
                        "    }",
                        "}",
                        "function GoodsAddPlayer(int type, int goodsCount) {",
                        "    int price = GoodsBuyPrice(NearCivilPlanet(Player()),type);",
                        "    ShipGoods(Player(),type,goodsCount,goodsCount*price);",
                        "}",
                        "function Char11GetBrokenUsless() {",
                        "    int rndFlag = Rnd(0,7);",
                        "    str uslessName;",
                        "    if (rndFlag ==0) uslessName = 'CargoHook';",
                        "    if (rndFlag ==1) uslessName = 'DefGenerator';",
                        "    if (rndFlag ==2) uslessName = 'Engine';",
                        "    if (rndFlag ==3) uslessName = 'FuelTanks';",
                        "    if (rndFlag ==4) uslessName = 'Radar';",
                        "    if (rndFlag ==5) uslessName = 'RepairRobot';",
                        "    if (rndFlag ==6) uslessName = 'Scaner';",
                        "    if (rndFlag ==7) uslessName = 'Weapon';",
                        "",
                        "    if (uslessName=='Weapon') uslessName = 'Broken'+uslessName+'_0'+Rnd(1,4);",
                        "    else uslessName = 'Broken'+uslessName+'_'+Rnd(1,2);",
                        "    result = uslessName;",
                        "}"
                    ]
                },
