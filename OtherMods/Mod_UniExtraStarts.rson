                        "    SetRelationsToPlayer('Good',0,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Best',0,1,0,0,0,0);",
                        "}",
                        "if (startRace == People) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Bad',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,1,0);",
                        "}",
                        "if (startRace == Fei) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',1,1,1,0,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,1,1,0);",
                        "}",
                        "if (startRace == Gaal) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
