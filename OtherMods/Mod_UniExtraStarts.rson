                    "Code": 
                    [
                        "//стартует как обычно но с улучшенным захватом и большим количеством промлазеров",
                        "if (startRace == Maloc) {",
                        "    SetRelationsToPlayer('Enemy',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Bad',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,0,1,1,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,0,1,0);",
                        "}",
                        "if (startRace == Peleng) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,0,1,1,0,0);",
                        "    SetRelationsToPlayer('Good',0,0,0,0,1,1);",
                        "    SetRelationsToPlayer('Best',0,1,0,0,0,0);",
                        "}",
                        "if (startRace == People) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,1);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,1,0);",
                        "}",
                        "if (startRace == Fei) {",
                        "    SetRelationsToPlayer('Enemy',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,0,1,1,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,0,1,0);",
                        "}",
                        "if (startRace == Gaal) {",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',0,1,0,0,0,1);",
                        "    SetRelationsToPlayer('Good',0,0,1,0,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,1,1,0);",
                        "",
                        "    ItemImprovement(ShipEqInSlot(Player(), t_CargoHook), 1, 0);",
                        "}",
                        "",
                        "ShipStatus(Player(), 0, 65); //Торговый статус",
                        "ShipStatus(Player(), 1, 10); //Пиратский статус",
                        "ShipStatus(Player(), 2, 25); //Военный статус",
                        "",
                        "if(CurrentMods('ShusRangers\\ShuBounty')) {",
                        "    str strUsl1 = '';",
                        "    str strUsl2 = '';",
                        "    str strUsl3 = '';",
                        "    int exclusion = 0;",
                        "    if (startRace == Maloc) {",
                        "        strUsl1 = '0';",
                        "        strUsl2 = '2';",
                        "        strUsl3 = '7';",
                        "    }",
                        "    if (startRace == Peleng) {",
                        "        strUsl1 = '13';",
                        "        strUsl2 = '14';",
                        "        strUsl3 = '18';",
                        "    }",
                        "    if (startRace == People) {",
                        "        strUsl1 = '19';",
                        "        strUsl2 = '20';",
                        "        strUsl3 = '21';",
                        "    }",
                        "    if (startRace == Fei) {",
                        "        strUsl1 = '29';",
                        "        strUsl2 = '36';",
                        "        strUsl3 = '37';",
                        "    }",
                        "    if (startRace == Gaal) {",
                        "        strUsl1 = '42';",
                        "        strUsl2 = '43';",
                        "        strUsl3 = '68';",
                        "    }",
                        "    exclusion = Rnd(0,2);",
                        "    if (exclusion==0) {",
                        "        AddItemToShip(Player(),CreateQuestItem('Usl_'+strUsl2,startRace));",
                        "        AddItemToShip(Player(),CreateQuestItem('Usl_'+strUsl3,startRace));",
                        "    }",
                        "    if (exclusion==1) {",
                        "        AddItemToShip(Player(),CreateQuestItem('Usl_'+strUsl1,startRace));",
                        "        AddItemToShip(Player(),CreateQuestItem('Usl_'+strUsl3,startRace));",
                        "    }",
                        "    if (exclusion==2) {",
                        "        AddItemToShip(Player(),CreateQuestItem('Usl_'+strUsl1,startRace));",
                        "        AddItemToShip(Player(),CreateQuestItem('Usl_'+strUsl2,startRace));",
                        "    }",
                        "}",
                        "else {",
                        "    GoodsAddPlayer(t_Minerals,50+Rnd(-5,15));",
                        "}",
                        "if(CurrentMods('Evolution\\EvoRepairBox')) {",
                        "    for (i=0;i<2;i=i+1) {",
                        "        AddItemToShip(Player(),CreateQuestItem(Char11GetBrokenUsless()));",
                        "    }",
                        "}",
                        "else {",
                        "    for (i=0;i<2;i=i+1) {",
                        "        item = CreateEquipment(Rnd(43,53),Rnd(20,49),Rnd(1,2),Rnd(0,4));",
                        "        ItemDurability(item,Rnd(1,10));",
                        "        AddItemToShip(Player(), item);",
                        "    }",
                        "}"
                    ]
                },
