                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": -10,
                    "Pos.y": -90,
                    "Parent": -1,
                    "#": 6,
                    "Code.Type": "DialogBegin",
                    "Code": 
                    [
                        "cur_ship = GetShipRuins(Player());",
                        "",
                        "if(cur_ship) {",
                        "    if(ShipType(cur_ship) == 'BK') {",
                        "        if(!PlayerDebtCnt()) {",
                        "            if(!joined_work) {",
                        "                AddDialogInject('AskForWork',CT('Script.Mod_RevMerchants.Vacancia'),CT('Script.Mod_RevMerchants.AskForVacancia'),2);",
                        "            }",
                        "            /*else if(!contract) {",
                        "                AddDialogInject('AskForContract','',\"Хочу поработать курьером\",2);",
                        "            }*/",
                        "        }",
                        "    }",
                        "    /*if(PlayerBridge(11)) {",
                        "        if(contract) {",
                        "            AddDialogInject('AskForContract','',\"Посмотреть информацию о текущем заказе\",2);",
                        "        }",
                        "    }*/",
                        "}",
                        "",
                        "cur_ship = GetShipPlanet(Player());",
                        "dword item;",
                        "",
                        "if(cur_ship) {",
                        "    if(CT(path+'.Quests.'+contract+'.ItemType') != t_UselessItem) {",
                        "        if(GoodsCount(Player(),CT(path+'.Quests.'+contract+'.ItemType')) == CT(path+'.Quests.'+contract+'.Count')) {",
                        "            AddDialogInject('RecieveCargo','',\"Я привёз груз согласно заказу...\",1);",
                        "        }",
                        "    }",
                        "    else {",
                        "        j = 0;",
                        "        for(i=0;i<ShipItems(Player());i=i+1) {",
                        "            item = ShipItems(Player(),i);",
                        "            if(ItemType(item) != t_UselessItem) continue;",
                        "            if(EquipmentImageName(item) != CT(path+'.Quests.'+contract+'.UselessType')) continue;",
                        "            j = j + 1;",
                        "        }",
                        "        if(j == CT(path+'.Quests.'+contract+'.Count')) {",
                        "            AddDialogInject('RecieveCargo','',\"Я привёз груз согласно заказу...\",1);",
                        "        }",
                        "    }",
                        "}"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": -50,
                    "Pos.y": -130,
                    "Parent": -1,
                    "#": 7,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "//Обновляем доступные контракты",
                        "if(UpdateCD) UpdateCD = UpdateCD - 1;",
                        "else {",
                        "    c1 = 0;",
                        "    c2 = 0;",
                        "    c3 = 0;",
                        "    f1 = 0;",
                        "    f2 = 0;",
                        "    f3 = 0;",
                        "    t1 = 0;",
                        "    t2 = 0;",
                        "    t3 = 0;",
                        "",
                        "    UpdateCD = PortionInDiapason(GalaxyDiffLevels(5),50,500,20,700) + Rnd(1,20);",
                        "}",
                        "",
                        "//Считаем кулдаун",
                        "if(days && joined_work) {",
                        "    DaysLeft = DaysLeft - 1;",
                        "    tdwd = IdToPlanet(PlanetFromId);",
                        "    tdwd2 = IdToPlanet(PlanetToId);",
                        "    Ether(3,'RevMerchantsEther',Format(CT(path+'.EtherText'),'<Days'+'>',DaysLeft,'<FromPlanet'+'>',Name(tdwd),'<FromStar'+'>',Name(PlanetToStar(tdwd)),'<FromSector'+'>',Name(StarToCon(PlanetToStar(tdwd))),'<ToPlanet'+'>',Name(tdwd2),'<ToStar'+'>',Name(PlanetToStar(tdwd2)),'<ToSector'+'>',Name(StarToCon(PlanetToStar(tdwd2)))));",
                        "}",
                        "//Даём проверку на сильное истечение срока",
                        "if(days && (DaysLeft < (days * 2)) && joined_work) {",
                        "    joined_work = 0;",
                        "    NewsAdd(Format(CT(path+'.QuestFailed'),'<Player'+'>',Name(Player())));",
                        "    Sound('Sound.QuestCancel');",
                        "    Ether(5,'RevMerchantsEther','');",
                        "    PlayerDebt(PlayerDebt()+Reward);",
                        "    if(!PlayerDebtDate()) PlayerDebtDate(CurTurn());",
                        "}"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": -10,
                    "Pos.y": -130,
                    "Parent": -1,
                    "#": 8,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "//Просто по приколу будем тут хранить путь до всех текстов и цифр мода",
                        "path = 'Script.Mod_RevMerchants';",
                        "",
                        "UpdateCD = Rnd(50,90);"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 100,
                    "Pos.y": -80,
                    "Parent": -1,
                    "#": 15,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "joined_work = 1;"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 280,
                    "Pos.y": -110,
                    "Parent": -1,
                    "#": 24,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "dword cur_star = ShipStar(Player());",
                        "tstr = '</color>' + CT(path + '.AskFor1');",
                        "",
                        "if(!c1 && ~c1) {",
                        "    c1 = Rnd(1,CT(path+'.Quests.Count'));",
                        "    for(i=0;StarPlanets(cur_star)>i;i=i+1) {",
                        "        if(PlanetOwner(StarPlanets(cur_star,i)) == None) continue;",
                        "        else {",
                        "            f1 = StarPlanets(cur_star,i);",
                        "        }",
                        "    }",
                        "",
                        "    for(i=1;StarNearbyStars(cur_star)>i;i=i+1) {",
                        "        if(round(sqrt(Dist2Star(cur_star, StarNearbyStars(cur_star,i)))) < 30) continue;",
                        "        dword to_star = StarNearbyStars(cur_star,i);",
                        "",
                        "        for(j=0;StarPlanets(to_star)>j;j=j+1) {",
                        "            if(PlanetOwner(StarPlanets(to_star,j)) == None) continue;",
                        "            else {",
                        "                t1 = StarPlanets(to_star,j);",
                        "            }",
                        "        }",
                        "    }",
                        "    if(!t1) {",
                        "        for(i=1;StarNearbyStars(cur_star)>i;i=i+1) {",
                        "            if(round(sqrt(Dist2Star(cur_star, StarNearbyStars(cur_star,i)))) < 20) continue;",
                        "            to_star = StarNearbyStars(cur_star,i);",
                        "",
                        "            for(j=0;StarPlanets(to_star)>j;j=j+1) {",
                        "                if(PlanetOwner(StarPlanets(to_star,j)) == None) continue;",
                        "                else {",
                        "                    t1 = StarPlanets(to_star,j);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    if(t1 && f1) {",
                        "        d1 = 35 + PortionInDiapason(round(sqrt(Dist2Star(PlanetToStar(f1), PlanetToStar(t1)))),20,150,10,120);",
                        "        m1 = GalaxyMoney(4,4) * 5 * PortionInDiapason(round(sqrt(Dist2Star(PlanetToStar(f1), PlanetToStar(t1)))),20,150,85,170) / 100;",
                        "    ",
                        "        tstr = tstr + Format('<br>') + '</color>' + Format(CT(path + '.AskFor2'),'<PlanetFrom'+'>',Name(f1),'<PlanetTo'+'>',Name(t1),'<Days'+'>',d1,'<Type'+'>',CT(path + '.Quests.'+c1+'.TypeName'),'<Weight'+'>',CT(path + '.Quests.'+c1+'.Count'),'<Money'+'>',m1);",
                        "    }",
                        "    else c1 = -1;",
                        "}",
                        "else if(~c1) tstr = tstr + Format('<br>') + '</color>' + Format(CT(path + '.AskFor2'),'<PlanetFrom'+'>',Name(f1),'<PlanetTo'+'>',Name(t1),'<Days'+'>',d1,'<Type'+'>',CT(path + '.Quests.'+c1+'.TypeName'),'<Weight'+'>',CT(path + '.Quests.'+c1+'.Count'),'<Money'+'>',m1);",
                        "if(!c2 && ~c2) {",
                        "    c2 = Rnd(1,CT(path+'.Quests.Count'));",
                        "    for(i=0;StarPlanets(cur_star)>i;i=i+1) {",
                        "        if(PlanetOwner(StarPlanets(cur_star,i)) == None) continue;",
                        "        else {",
                        "            f2 = StarPlanets(cur_star,i);",
                        "        }",
                        "    }",
                        "",
                        "    for(i=1;StarNearbyStars(cur_star)>i;i=i+1) {",
                        "        if(round(sqrt(Dist2Star(cur_star, StarNearbyStars(cur_star,i)))) < 30) continue;",
                        "        to_star = StarNearbyStars(cur_star,i);",
                        "",
                        "        for(j=0;StarPlanets(to_star)>j;j=j+1) {",
                        "            if(PlanetOwner(StarPlanets(to_star,j)) == None) continue;",
                        "            else {",
                        "                t2 = StarPlanets(to_star,j);",
                        "            }",
                        "        }",
                        "    }",
                        "    if(!t2) {",
                        "        for(i=1;StarNearbyStars(cur_star)>i;i=i+1) {",
                        "            if(round(sqrt(Dist2Star(cur_star, StarNearbyStars(cur_star,i)))) < 20) continue;",
                        "            to_star = StarNearbyStars(cur_star,i);",
                        "",
                        "            for(j=0;StarPlanets(to_star)>j;j=j+1) {",
                        "                if(PlanetOwner(StarPlanets(to_star,j)) == None) continue;",
                        "                else {",
                        "                    t2 = StarPlanets(to_star,j);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "    if(t2 && f2) {",
                        "        d2 = 35 + PortionInDiapason(round(sqrt(Dist2Star(PlanetToStar(f2), PlanetToStar(t2)))),20,150,10,120);",
                        "        m2 = GalaxyMoney(4,4) * 5 * PortionInDiapason(round(sqrt(Dist2Star(PlanetToStar(f2), PlanetToStar(t2)))),20,150,85,170) / 100;",
                        "",
                        "        tstr = tstr + Format('<br>') + '</color>' + Format(CT(path + '.AskFor2'),'<PlanetFrom'+'>',Name(f2),'<PlanetTo'+'>',Name(t2),'<Days'+'>',d2,'<Type'+'>',CT(path + '.Quests.'+c2+'.TypeName'),'<Weight'+'>',CT(path + '.Quests.'+c2+'.Count'),'<Money'+'>',m2);",
                        "    }",
                        "    else c2 = -1;",
                        "}",
                        "else if(~c2) tstr = tstr + Format('<br>') + '</color>' + Format(CT(path + '.AskFor2'),'<PlanetFrom'+'>',Name(f2),'<PlanetTo'+'>',Name(t2),'<Days'+'>',d2,'<Type'+'>',CT(path + '.Quests.'+c2+'.TypeName'),'<Weight'+'>',CT(path + '.Quests.'+c2+'.Count'),'<Money'+'>',m2);",
                        "if(!c3 && ~c3) {",
                        "    c3 = Rnd(1,CT(path+'.Quests.Count'));",
                        "    for(i=0;StarPlanets(cur_star)>i;i=i+1) {",
                        "        if(PlanetOwner(StarPlanets(cur_star,i)) == None) continue;",
                        "        else {",
                        "            f3 = StarPlanets(cur_star,i);",
                        "        }",
                        "    }",
                        "",
                        "    for(i=1;StarNearbyStars(cur_star)>i;i=i+1) {",
                        "        if(round(sqrt(Dist2Star(cur_star, StarNearbyStars(cur_star,i)))) < 30) continue;",
                        "        to_star = StarNearbyStars(cur_star,i);",
                        "",
                        "        for(j=0;StarPlanets(to_star)>j;j=j+1) {",
                        "            if(PlanetOwner(StarPlanets(to_star,j)) == None) continue;",
                        "            else {",
                        "                t3 = StarPlanets(to_star,j);",
                        "            }",
                        "        }",
                        "    }",
                        "    if(!t3) {",
                        "        for(i=1;StarNearbyStars(cur_star)>i;i=i+1) {",
                        "            if(round(sqrt(Dist2Star(cur_star, StarNearbyStars(cur_star,i)))) < 20) continue;",
                        "            to_star = StarNearbyStars(cur_star,i);",
                        "",
                        "            for(j=0;StarPlanets(to_star)>j;j=j+1) {",
                        "                if(PlanetOwner(StarPlanets(to_star,j)) == None) continue;",
                        "                else {",
                        "                    t3 = StarPlanets(to_star,j);",
                        "                }",
                        "            }",
                        "        }",
                        "    }",
                        "",
                        "",
                        "    if(t3 && f3) {",
                        "        d3 = 35 + PortionInDiapason(round(sqrt(Dist2Star(PlanetToStar(f3), PlanetToStar(t3)))),20,150,10,120);",
                        "        m3 = GalaxyMoney(4,4) * 5 * PortionInDiapason(round(sqrt(Dist2Star(PlanetToStar(f3), PlanetToStar(t3)))),20,150,85,170) / 100;",
                        "",
                        "       tstr = tstr + Format('<br>') + '</color>' + Format(CT(path + '.AskFor2'),'<PlanetFrom'+'>',Name(f3),'<PlanetTo'+'>',Name(t3),'<Days'+'>',d3,'<Type'+'>',CT(path + '.Quests.'+c3+'.TypeName'),'<Weight'+'>',CT(path + '.Quests.'+c3+'.Count'),'<Money'+'>',m3);",
                        "    }",
                        "    else c3 = -1;",
                        "}",
                        "else if(~c3) tstr = tstr + Format('<br>') + '</color>' + Format(CT(path + '.AskFor2'),'<PlanetFrom'+'>',Name(f3),'<PlanetTo'+'>',Name(t3),'<Days'+'>',d3,'<Type'+'>',CT(path + '.Quests.'+c3+'.TypeName'),'<Weight'+'>',CT(path + '.Quests.'+c3+'.Count'),'<Money'+'>',m3);",
                        "",
                        "if(c1 == -1 && c2 == -1 && c3 == -1) tstr = tstr + Format('<br>') + '</color>' + CT(path + '.AskForNo');",
                        "",
                        "tstr = tstr + Format('<br>') + '</color>' + CT(path + '.AskFor3');"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 320,
                    "Pos.y": -110,
                    "Parent": -1,
                    "#": 25,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "//"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 450,
                    "Pos.y": -150,
                    "Parent": -1,
                    "#": 33,
                    "Code.Type": "Turn",
                    "Code": 
                    [
                        "if(Days > (daysLeft * 2)) {",
                        "    i = Reward * 115 / 100;",
                        "    tstr = '</color>' + Format(CT(path+'.RecievedEarlier'),'<Player'+'>',Name(Player()),'<Money'+'>',i);",
                        "}",
                        "else if(daysLeft) {",
                        "    i = Reward;",
                        "    tstr = '</color>' + Format(CT(path+'.RecievedEarlier'),'<Player'+'>',Name(Player()),'<Money'+'>',i);",
                        "}",
                        "else if(daysLeft < Days * 2) {",
                        "    i = Reward / 50;",
                        "    tstr = '</color>' + Format(CT(path+'.RecievedEarlier'),'<Player'+'>',Name(Player()),'<Money'+'>',i);",
                        "}",
                        "else {",
                        "    tstr = '</color>' + Format(CT(path+'.RecievedEarlier'),'<Player'+'>',Name(Player()));",
                        "}",
                        "",
                        "if(CT(path+'.Quests.'+contract+'.Contraband')) {",
                        "    RelationToRanger(GetShipPlanet(Player()),Player(),RelationToRanger(GetShipPlanet(Player()),Player()) - Rnd(30,50));",
                        "}",
                        "else if(CT(path+'.Quests.'+contract+'.ItemType') != t_UselessItem) {",
                        "    if(ShipGoodsIllegalOnPlanet(Player(),CT(path+'.Quests.'+contract+'.ItemType'),GetShipPlanet(Player()))) {",
                        "        RelationToRanger(GetShipPlanet(Player()),Player(),RelationToRanger(GetShipPlanet(Player()),Player()) - Rnd(30,50));",
                        "    }",
                        "}",
                        "",
                        "",
                        "    if(CT(path+'.Quests.'+contract+'.ItemType') != t_UselessItem) {",
                        "        if(GoodsCount(Player(),CT(path+'.Quests.'+contract+'.ItemType')) == CT(path+'.Quests.'+contract+'.Count')) {",
                        "            ShipGoods(Player(),CT(path+'.Quests.'+contract+'.ItemType'),-CT(path+'.Quests.'+contract+'.Count'));",
                        "        }",
                        "    }",
                        "    else {",
                        "        for(i=ShipItems(Player());i>0;i=i-1) {",
                        "            item = ShipItems(Player(),i);",
                        "            if(ItemType(item) != t_UselessItem) continue;",
                        "            if(EquipmentImageName(item) != CT(path+'.Quests.'+contract+'.UselessType')) continue;",
                        "            FreeItem(GetItemFromShip(Player(),item));",
                        "        }",
                        "    }",
                        "",
                        "",
                        "Sound('Sound.QuestOk');"
                    ]
                },
                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 280,
                    "Pos.y": 10,
                    "Parent": -1,
                    "#": 41,
                    "Code.Type": "Turn",
