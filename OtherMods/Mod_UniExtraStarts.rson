                {
                    "Type": "Top",
                    "Name": "",
                    "Pos.x": 40,
                    "Pos.y": 0,
                    "Parent": 28,
                    "#": 11,
                    "Code.Type": "Init",
                    "Code": 
                    [
                        "//у спецагентов просто накладываем акрин, в остальном старт обычный",
                        "if (startRace == Maloc) {",
                        "    SetRelationsToPlayer('Bad',0,0,1,1,0,1);",
                        "    SetRelationsToPlayer('Normal',0,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Good',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Best',1,0,0,0,0,0);",
                        "",
                        "    GiveReward(Player(),Maloc,2);",
                        "    GiveReward(Player(),Maloc,2);",
                        "}",
                        "if (startRace == Peleng) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,1,0,0);",
                        "    SetRelationsToPlayer('Bad',0,0,1,0,1,0);",
                        "    SetRelationsToPlayer('Normal',1,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Best',0,1,0,0,0,0);",
                        "",
                        "    GiveReward(Player(),Peleng,2);",
                        "    GiveReward(Player(),Peleng,2);",
                        "}",
                        "if (startRace == People) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Bad',0,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Normal',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',0,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,0,0);",
                        "",
                        "    GiveReward(Player(),Rnd(0,4),2);",
                        "    GiveReward(Player(),Rnd(0,4),2);",
                        "}",
                        "if (startRace == Fei) {",
                        "    SetRelationsToPlayer('Enemy',0,1,0,0,0,1);",
                        "    SetRelationsToPlayer('Bad',1,0,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',0,0,0,0,1,0);",
                        "    SetRelationsToPlayer('Best',0,0,1,1,0,0);",
                        "",
                        "    GiveReward(Player(),Fei,2);",
                        "    GiveReward(Player(),People,2);",
                        "}",
                        "if (startRace == Gaal) {",
                        "    SetRelationsToPlayer('Enemy',0,0,0,0,0,1);",
                        "    SetRelationsToPlayer('Bad',1,1,0,0,0,0);",
                        "    SetRelationsToPlayer('Good',0,0,1,1,0,0);",
                        "    SetRelationsToPlayer('Best',0,0,0,0,1,0);",
                        "",
                        "    GiveReward(Player(),Gaal,2);",
                        "    GiveReward(Player(),Gaal,2);",
                        "}",
                        "",
                        "",
                        "SpecialToEquipment(FindBonusByNameInCfg('480'),ShipEqInSlot(Player(),t_Hull));",
                        "Chameleon(Player());",
                        "",
                        "ShipStatus(Player(), 0, 25); //Торговый статус",
                        "ShipStatus(Player(), 1,  0); //Пиратский статус",
                        "ShipStatus(Player(), 2, 75); //Военный статус",
                        "",
                        "ItemImprovement(ShipEqInSlot(Player(), t_Engine), 1, 0);"
                    ]
                },
